# App Configuration
APP_NAME=FileShareSystem
APP_ENV=development
DEBUG=True
SECRET_KEY=yoursecretkey_changeme_in_production

# Database Configuration (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=filesharingsystem
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/filesharingsystem

# Redis (optional — enable for production upload session tracking)
REDIS_ENABLED=False
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Local File Storage
UPLOAD_DIR=./uploads
