# App Configuration
APP_NAME=FileShareSystem
APP_ENV=development
DEBUG=True
SECRET_KEY=yoursecretkey_changeme_in_production

# Database Configuration (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=filesharingsystem
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/filesharingsystem

# Redis (optional — enable for production upload session tracking)
REDIS_ENABLED=False
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Local File Storage
UPLOAD_DIR=./uploads

# Public Base URL — used to build share links sent to the frontend.
# Using the raw LAN IP (192.168.1.5) instead of the .local mDNS hostname
# because Android does not reliably resolve .local addresses.
# Both your Mac, iPhone, and Android phone must be on the same WiFi network.
# If your router assigns a different IP to your Mac, update this value.
# Run `ipconfig getifaddr en0` in Terminal to find your current LAN IP.
PUBLIC_BASE_URL=http://192.168.1.5:8000
