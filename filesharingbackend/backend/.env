# ─── App ───────────────────────────────────────────
APP_NAME=FileShareSystem
APP_ENV=development          # development | production
DEBUG=True
SECRET_KEY=fd6f2a807beeeb2b456ba354bf643150051f3c70ffa39041833d980f7a233965a
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ──────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=filesharingsystem
POSTGRES_HOST=db              # docker service name
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/filesharingsystem

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=redis              # docker service name
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Storage (S3 / MinIO) ──────────────────────────
STORAGE_BACKEND=minio         # minio | s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-south-1
S3_BUCKET_NAME=filesharebucket
MINIO_ENDPOINT=http://minio:9000

# ─── File Settings ─────────────────────────────────
MAX_FILE_SIZE_BYTES=5368709120   # 5 GB
CHUNK_SIZE_BYTES=5242880         # 5 MB per chunk
SHARE_LINK_EXPIRY_HOURS=72       # 3 days default
UPLOAD_SESSION_TTL_SECONDS=3600  # 1 hour to complete upload

# ─── CDN ───────────────────────────────────────────
CDN_BASE_URL=http://localhost:9000/filesharebucket
