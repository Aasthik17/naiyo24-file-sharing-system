# App Configuration
APP_NAME=FileShareSystem
APP_ENV=development
DEBUG=True
SECRET_KEY=yoursecretkey_changeme_in_production

# Database Configuration (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=filesharingsystem
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/filesharingsystem

# Local File Storage
UPLOAD_DIR=./uploads

# Public URL for share links (so they're reachable from other devices)
# Set to your machine's LAN IP or public domain, e.g.:
#   PUBLIC_BASE_URL=http://192.168.1.5:8000
# Leave empty to auto-detect your LAN IP.
PUBLIC_BASE_URL=
